<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <title>{% block title %}Admin{% endblock %}</title>

    <!-- Bootstrap -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <!-- CSS do sistema -->
    <link rel="stylesheet" href="/assets/css/logs.css">
    <link rel="stylesheet" href="/assets/css/admin.css?v={{ random() }}">
    <link rel="stylesheet" href="/assets/css/badges.css">

    {% block head %}{% endblock %}
</head>

<body>

<div class="admin-wrapper d-flex">

    {# ============================================================
       SIDEBAR
       ============================================================ #}
    <aside class="sidebar">

        <div class="logo">Painel Admin</div>

        <nav class="sidebar-nav">
            <ul>

                {% for item in menuAdmin %}

                    {# HEADER #}
                    {% if item.header is defined %}
                        <li class="menu-header">{{ item.header }}</li>

                    {% else %}

                        {# PERMISSÕES #}
                        {% if auth.user.isAdmin() or auth.user.hasPermissao(item.permissao) %}

                            {# ACTIVE #}
                            {% set active = (app.request.path starts with item.url) ? 'active' : '' %}

                            <li class="menu-item {{ active }}">

                                <a href="{{ item.url }}"
                                   class="menu-link {% if item.principal is defined and item.principal %}main{% endif %}">

                                    {% if item.icone is defined %}
                                        <i class="bi {{ item.icone }}"></i>
                                    {% endif %}

                                    <span>{{ item.titulo }}</span>

                                    {% if item.sub is defined %}
                                        <i class="bi bi-chevron-right submenu-arrow"></i>
                                    {% endif %}

                                    {% if item.badge is defined and item.badge > 0 %}
                                        <span class="badge">{{ item.badge }}</span>
                                    {% endif %}
                                </a>

                                {# SUBMENU #}
                                {% if item.sub is defined %}
                                    <ul class="submenu-list">

                                        {% for sub in item.sub %}
                                            {% if auth.user.isAdmin() or auth.user.hasPermissao(sub.permissao) %}

                                                {% set subActive = (app.request.path == sub.url) ? 'active' : '' %}

                                                <li class="submenu-item {{ subActive }}">
                                                    <a href="{{ sub.url }}" class="submenu-link">
                                                        {{ sub.titulo }}
                                                    </a>
                                                </li>

                                            {% endif %}
                                        {% endfor %}

                                    </ul>
                                {% endif %}

                            </li>

                        {% endif %}
                    {% endif %}

                {% endfor %}

            </ul>
        </nav>

    </aside>

    {# ============================================================
       ÁREA PRINCIPAL
       ============================================================ #}
    <main class="content-area flex-grow-1">

        {# TOPBAR PREMIUM #}
        <header class="topbar d-flex align-items-center justify-content-between px-4">

            <button class="btn-toggle-sidebar me-3">
                <i class="bi bi-list"></i>
            </button>

            <div class="page-title flex-grow-1">
                {% block page_title %}{% endblock %}
            </div>

            <div class="user-info d-flex align-items-center gap-2 dropdown"
                 data-bs-toggle="dropdown" style="cursor:pointer;">
                <span class="user-name">{{ auth.user.nome }}</span>
                <img src="/assets/img/avatar.png" class="avatar rounded-circle">
            </div>

            <ul class="dropdown-menu dropdown-menu-end">
                <li><a class="dropdown-item" href="/admin/perfil"><i class="bi bi-person"></i> Perfil</a></li>
                <li><a class="dropdown-item" href="/admin/definicoes"><i class="bi bi-gear"></i> Definições</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> Sair</a></li>
            </ul>

        </header>

        {# CONTEÚDO DA PÁGINA #}
        <section class="page-content">
            {% include "@admin/flash.twig" %}
            {% block content %}{% endblock %}
        </section>

    </main>

</div>

<!-- JS -->
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

{# ============================================================
   JS — SIDEBAR TOGGLE (DESKTOP + MOBILE)
============================================================ #}
<script>
    const toggleBtn = document.querySelector('.btn-toggle-sidebar');

    toggleBtn.addEventListener('click', function () {
        // Mobile
        if (window.innerWidth <= 992) {
            document.body.classList.toggle('sidebar-open');
        }
        // Desktop
        else {
            document.body.classList.toggle('sidebar-collapsed');
        }
    });
</script>

{# ============================================================
   JS — SUBMENU PREMIUM
============================================================ #}
<script>
    document.querySelectorAll('.menu-item').forEach(function (item) {

        const link = item.querySelector('.menu-link');
        const submenu = item.querySelector('.submenu-list');

        if (!submenu) return;

        link.addEventListener('click', function (e) {
            e.preventDefault();
            item.classList.toggle('open');
        });

        if (item.classList.contains('active')) {
            item.classList.add('open');
        }
    });
</script>

{% block scripts %}{% endblock %}
{% block modals %}{% endblock %}

</body>
</html>