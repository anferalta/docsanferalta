{% extends "@admin/layout.twig" %}

{% block title %}Gestão de Utilizadores{% endblock %}
{% block header %}Gestão de Utilizadores{% endblock %}

{% block content %}

<div class="container">

    <!-- TÍTULO + BOTÃO -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold">Utilizadores</h3>

        {% if acl.has('admin.utilizadores.criar') %}
            <a href="/admin/utilizadores/criar" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i> Novo Utilizador
            </a>
        {% endif %}
    </div>

    <!-- FILTROS -->
    <form method="get" class="row g-3 mb-4">

        <div class="col-md-3">
            <input type="text" name="nome" class="form-control"
                   placeholder="Nome"
                   value="{{ nome }}">
        </div>

        <div class="col-md-3">
            <input type="text" name="email" class="form-control"
                   placeholder="Email"
                   value="{{ email }}">
        </div>

        <div class="col-md-3">
            <select name="ativo" class="form-select">
                <option value="">Estado</option>
                <option value="1" {{ ativo == '1' ? 'selected' }}>Ativo</option>
                <option value="0" {{ ativo == '0' ? 'selected' }}>Inativo</option>
            </select>
        </div>

        <div class="col-md-3">
            <button class="btn btn-primary w-100">Filtrar</button>
        </div>

    </form>

    <!-- TABELA -->
    <div class="card shadow-sm">
        <div class="card-body">

            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Email</th>
                        <th>Perfil</th>
                        <th>Estado</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>

                <tbody>
                    {% for u in utilizadores %}
                        <tr>
                            <td>{{ u.id }}</td>
                            <td>{{ u.nome }}</td>
                            <td>{{ u.email }}</td>
                            <td>{{ u.perfil_nome ?? '—' }}</td>

                            <td>
                                {% if u.ativo == 1 %}
                                    <span class="badge bg-success">Ativo</span>
                                {% else %}
                                    <span class="badge bg-danger">Inativo</span>
                                {% endif %}
                            </td>

                            <td class="text-end">

                                <a href="{{ url('admin/utilizadores/editar/' ~ u.id) }}"
                                   class="btn btn-sm btn-warning">Editar</a>

                                <a href="{{ url('admin/utilizadores/eliminar/' ~ u.id) }}"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Tem a certeza que deseja apagar?')">
                                   Apagar
                                </a>

                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>

            <!-- PAGINAÇÃO -->
            <nav>
                <ul class="pagination justify-content-center">
                    {% for p in 1..total_paginas %}
                        <li class="page-item {{ p == pagina ? 'active' : '' }}">
                            <a class="page-link"
                               href="?page={{ p }}&nome={{ nome }}&email={{ email }}&ativo={{ ativo }}">
                                {{ p }}
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            </nav>

        </div>
    </div>

</div>

{% endblock %}