{% extends "@admin/layout.twig" %}

{% block title %}Editar Utilizador{% endblock %}
{% block header %}Editar Utilizador{% endblock %}

{% block content %}

    <div class="card shadow-sm p-4">
        <form method="post" action="/admin/utilizadores/editar/{{ utilizador.id }}">

            {{ csrf_field() }}

            <div class="mb-3">
                <label class="form-label fw-semibold">Nome</label>
                <input type="text" name="nome" class="form-control" value="{{ utilizador.nome }}" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Email</label>
                <input type="email" name="email" class="form-control" value="{{ utilizador.email }}" required>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Perfil</label>
                <select name="perfil_id" class="form-select" required>
                    {% for p in perfis %}
                        <option value="{{ p.id }}" {% if p.id == utilizador.perfil_id %}selected{% endif %}>
                            {{ p.nome }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Estado</label>
                <select name="ativo" class="form-select">
                    <option value="1" {% if utilizador.ativo == 1 %}selected{% endif %}>Ativo</option>
                    <option value="0" {% if utilizador.ativo == 0 %}selected{% endif %}>Inativo</option>
                </select>
            </div>

            <!-- ⭐ ALTERAR PASSWORD (OPCIONAL) -->
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="togglePassword"
                       onclick="document.getElementById('passwordFields').classList.toggle('d-none')">
                <label class="form-check-label fw-semibold" for="togglePassword">
                    Alterar Password
                </label>
            </div>

            <div id="passwordFields" class="d-none">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Nova Password</label>
                    <input type="password" name="password" class="form-control">
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Confirmar Password</label>
                    <input type="password" name="password_confirmation" class="form-control">
                </div>
            </div>

            <button class="btn btn-primary">Guardar Alterações</button>
            <a href="/admin/utilizadores" class="btn btn-secondary">Cancelar</a>

        </form>
    </div>

{% endblock %}