{% extends "@admin/layout.twig" %}

{% block page_title %}Áreas de Tramitação{% endblock %}

{% block content %}

    <div class="d-flex justify-content-between mb-3">
        <h4>Áreas</h4>
        <a href="{{ route('admin.documento_areas.criar') }}" class="btn btn-primary">Criar Área</a>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Código</th>
                        <th>Ativo</th>
                        <th width="150">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for a in areas %}
                        <tr>
                            <td>{{ a.nome }}</td>
                            <td>{{ a.codigo }}</td>
                            <td>{{ a.ativo ? 'Sim' : 'Não' }}</td>
                            <td>
                                <a href="{{ route('admin.documento_areas.editar', {id: a.id}) }}" class="btn btn-sm btn-warning">Editar</a>

                                <form method="POST" action="{{ route('admin.documento_areas.apagar', {id: a.id}) }}" class="d-inline">
                                    {{ csrf_field() }}
                                    <button type="submit"
                                            class="btn btn-sm btn-danger"
                                            onclick="event.stopPropagation();
                return confirm('Apagar área?')">
                                        Apagar
                                    </button>

                                </form>

                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="text-center py-3">Nenhuma área criada.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}

