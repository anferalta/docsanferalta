{% extends "@admin/layout.twig" %}

{% block header %} Gestão de Logs {% endblock %}
{% block title %} Logs {% endblock %}

{% block content %}
<h3 class="mb-4">Logs do Sistema</h3>

<div class="card mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">

            <div class="col-md-2 col-sm-6">
                <label class="form-label">Tipo</label>
                <select name="tipo" class="form-select">
                    <option value="">-- Todos --</option>
                    {% for t in ['erro','excecao','fatal','aviso','info','debug'] %}
                        <option value="{{ t }}" {{ filtros.tipo == t ? 'selected' }}>
                            {{ t|capitalize }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="col-md-2 col-sm-6">
                <label class="form-label">IP</label>
                <input type="text" name="ip" value="{{ filtros.ip }}" class="form-control" placeholder="127.0.0.1">
            </div>

            <div class="col-md-2 col-sm-6">
                <label class="form-label">Data início</label>
                <input type="date" name="data_inicio" value="{{ filtros.data_inicio }}" class="form-control">
            </div>

            <div class="col-md-2 col-sm-6">
                <label class="form-label">Data fim</label>
                <input type="date" name="data_fim" value="{{ filtros.data_fim }}" class="form-control">
            </div>

            <div class="col-md-3 col-sm-12">
                <label class="form-label">Mensagem contém</label>
                <input type="text" name="mensagem" value="{{ filtros.mensagem }}" class="form-control"
                       placeholder="texto da mensagem">
            </div>

            <div class="col-md-1 col-sm-12 d-grid">
                <button type="submit" class="btn btn-primary">Filtrar</button>
            </div>

        </form>

        <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap">
            <small class="text-muted mb-2">
                {% if logs|length > 0 %}
                    A mostrar {{ logs|length }} registos.
                {% else %}
                    Nenhum registo encontrado.
                {% endif %}
            </small>

            <div class="mb-2">
                <a href="/admin/logs/exportar?{{ app.request.queryString|replace({'p=':''}) }}"
                   class="btn btn-sm btn-success">Exportar CSV</a>

                <a href="/admin/logs" class="btn btn-sm btn-outline-secondary ms-2">Limpar filtros</a>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 70px;">ID</th>
                <th style="width: 120px;">Tipo</th>
                <th>Mensagem</th>
                <th style="width: 140px;">IP</th>
                <th style="width: 180px;">Data</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ log.id }}</td>

                    <td>
                        <span class="badge bg-{{
                            log.tipo in ['erro','fatal'] ? 'danger' :
                            log.tipo == 'excecao' ? 'warning' :
                            log.tipo == 'aviso' ? 'info' :
                            log.tipo == 'debug' ? 'secondary' : 'primary'
                        }}">
                            {{ log.tipo }}
                        </span>
                    </td>

                    <td title="{{ log.mensagem }}">
                        {% set msg = log.mensagem %}
                        {% if filtros.mensagem %}
                            {{ msg|replace({ (filtros.mensagem): '<mark>' ~ filtros.mensagem ~ '</mark>' })|raw }}
                        {% else %}
                            {{ msg|slice(0, 60) }}{% if msg|length > 60 %}...{% endif %}
                        {% endif %}
                    </td>

                    <td><span class="badge bg-light text-dark">{{ log.ip }}</span></td>

                    <td>{{ log.criado_em|date("d M Y H:i") }}</td>

                    <td>
                        <a href="/admin/logs/{{ log.id }}" class="btn btn-sm btn-outline-secondary">Ver</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        Nenhum registo encontrado com os filtros atuais.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% if paginas > 1 %}
    <nav aria-label="Paginação de logs">
        <ul class="pagination justify-content-center flex-wrap">
            <li class="page-item {{ pagina == 1 ? 'disabled' }}">
                <a class="page-link" href="?p=1">Primeira</a>
            </li>

            <li class="page-item {{ pagina == 1 ? 'disabled' }}">
                <a class="page-link" href="?p={{ pagina - 1 }}">Anterior</a>
            </li>

            {% for p in 1..paginas %}
                <li class="page-item {{ p == pagina ? 'active' }}">
                    <a class="page-link" href="?p={{ p }}">{{ p }}</a>
                </li>
            {% endfor %}

            <li class="page-item {{ pagina == paginas ? 'disabled' }}">
                <a class="page-link" href="?p={{ pagina + 1 }}">Seguinte</a>
            </li>

            <li class="page-item {{ pagina == paginas ? 'disabled' }}">
                <a class="page-link" href="?p={{ paginas }}">Última</a>
            </li>
        </ul>
    </nav>
{% endif %}

{% endblock %}
