{% extends "@admin/layout.twig" %}

{% block header %} Gestão de Logs {% endblock %}
{% block title %} Logs {% endblock %}

{% block content %}
    <h3 class="mb-4">Logs do Sistema</h3>

    <div class="card mb-3">
        <div class="card-body">
            <form method="get" class="row g-3 align-items-end">

                <div class="col-md-2">
                    <label class="form-label">Tipo</label>
                    <input type="text" name="tipo" value="{{ filtros.tipo }}" class="form-control"
                           placeholder="erro, excecao, fatal...">
                </div>

                <div class="col-md-2">
                    <label class="form-label">IP</label>
                    <input type="text" name="ip" value="{{ filtros.ip }}" class="form-control"
                           placeholder="127.0.0.1">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Data início</label>
                    <input type="date" name="data_inicio" value="{{ filtros.data_inicio }}" class="form-control">
                </div>

                <div class="col-md-2">
                    <label class="form-label">Data fim</label>
                    <input type="date" name="data_fim" value="{{ filtros.data_fim }}" class="form-control">
                </div>

                <div class="col-md-3">
                    <label class="form-label">Mensagem contém</label>
                    <input type="text" name="mensagem" value="{{ filtros.mensagem }}" class="form-control"
                           placeholder="texto da mensagem">
                </div>

                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary">Filtrar</button>
                </div>

            </form>

            <div class="mt-3 d-flex justify-content-between align-items-center">
                <small class="text-muted">
                    {% if logs|length > 0 %}
                        A mostrar {{ logs|length }} registos.
                    {% else %}
                        Nenhum registo encontrado.
                    {% endif %}
                </small>

                <a href="/admin/logs/exportar?{{ app.request.queryString|default('') }}" class="btn btn-sm btn-success">
                    Exportar CSV
                </a>
            </div>
        </div>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th style="width: 70px;">ID</th>
                <th style="width: 120px;">Tipo</th>
                <th>Mensagem</th>
                <th style="width: 140px;">IP</th>
                <th style="width: 180px;">Data</th>
                <th style="width: 80px;"></th>
            </tr>
        </thead>
        <tbody>
            {% for log in logs %}
                <tr>
                    <td>{{ log.id }}</td>
                    <td>
                        <span class="badge" data-tipo="{{ log.tipo }}">
                            {{ log.tipo }}
                        </span>
                    </td>
                    <td>{{ log.mensagem|slice(0, 60) }}{% if log.mensagem|length > 60 %}...{% endif %}</td>
                    <td>{{ log.ip }}</td>
                    <td>{{ log.criado_em }}</td>
                    <td>
                        <a href="/admin/logs/{{ log.id }}" class="btn btn-sm btn-outline-secondary">Ver</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">
                        Nenhum registo encontrado com os filtros atuais.
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

    {% if paginas > 1 %}
        <nav aria-label="Paginação de logs">
            <ul class="pagination justify-content-center">
                {% for p in 1..paginas %}
                    <li class="page-item {{ p == pagina ? 'active' }}">
                        <a class="page-link"
                           href="?p={{ p }}
                           {% if filtros.tipo %}&tipo={{ filtros.tipo }}{% endif %}
                           {% if filtros.ip %}&ip={{ filtros.ip }}{% endif %}
                           {% if filtros.data_inicio %}&data_inicio={{ filtros.data_inicio }}{% endif %}
                           {% if filtros.data_fim %}&data_fim={{ filtros.data_fim }}{% endif %}
                           {% if filtros.mensagem %}&mensagem={{ filtros.mensagem }}{% endif %}
                           ">
                            {{ p }}
                        </a>
                    </li>
                {% endfor %}
            </ul>
        </nav>
    {% endif %}
{% endblock %}