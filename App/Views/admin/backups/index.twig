{% extends "@admin/layout.twig" %}
{% block title %}Backups{% endblock %}
{% block page_title %}Gestão de Backups{% endblock %}

{% block content %}

    {% if flash.success %}
        <div class="alert alert-success">{{ flash.success }}</div>
    {% endif %}
    {% if flash.error %}
        <div class="alert alert-danger">{{ flash.error }}</div>
    {% endif %}

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link active" data-bs-toggle="tab" href="#bd">Base de Dados</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#files">Ficheiros</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#dashboard">Dashboard</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" data-bs-toggle="tab" href="#logs">Logs</a>
        </li>        
    </ul>

    <div class="tab-content">

        {# ---------------- TAB BASE DE DADOS ---------------- #}
        <div class="tab-pane fade show active" id="bd">
            <div class="card">
                <div class="card-body">

                    <a href="/admin/backups/bd/criar" class="btn btn-primary mb-3">Criar Backup da BD</a>
                    <a href="/admin/agendamentos" class="btn btn-outline-primary mb-3 ms-2">Gerir Agendamentos</a>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Tamanho</th>
                                <th>Data</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for b in backupsDB %}
                                <tr>
                                    <td>{{ b.nome }}</td>
                                    <td>{{ b.tamanho }}</td>
                                    <td>{{ b.data }}</td>
                                    <td class="text-end">

                                        {# DOWNLOAD BD #}
                                        <a href="/admin/backups/bd/download/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-primary">Download</a>

                                        {# RESTAURAR BD #}
                                        <a href="/admin/backups/bd/restaurar/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-warning">Restaurar</a>

                                        {# RESTAURAR + REINICIAR SERVIÇO #}
                                        <a href="/admin/backups/bd/restaurar-reiniciar/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Tem a certeza? Isto vai restaurar a BD e reiniciar o servidor?');">
                                            Restaurar + Reiniciar
                                        </a><a href="/admin/backups/bd/restaurar-reiniciar/{{ b.path|replace({'/':'---'}) }}"

                                        {# ELIMINAR BD #}
                                        <a href="/admin/backups/bd/delete/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Eliminar este backup?');">Eliminar</a>

                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="4" class="text-center text-muted">Nenhum backup.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        {# ---------------- TAB FICHEIROS ---------------- #}
        <div class="tab-pane fade" id="files">
            <div class="card">
                <div class="card-body">

                    <a href="/admin/backups/files/criar" class="btn btn-primary mb-3">Criar Backup dos Ficheiros</a>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Nome</th>
                                <th>Tamanho</th>
                                <th>Data</th>
                                <th class="text-end">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for b in backupsFiles %}
                                <tr>
                                    <td>{{ b.nome }}</td>
                                    <td>{{ b.tamanho }}</td>
                                    <td>{{ b.data }}</td>
                                    <td class="text-end">

                                        {# DOWNLOAD FICHEIROS #}
                                        <a href="/admin/backups/files/download/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-primary">Download</a>

                                        {# RESTAURAR FICHEIROS #}
                                        <a href="/admin/backups/files/restaurar/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-warning">Restaurar</a>

                                        {# ELIMINAR FICHEIROS #}
                                        <a href="/admin/backups/files/delete/{{ b.path|replace({'/':'---'}) }}"
                                           class="btn btn-sm btn-danger"
                                           onclick="return confirm('Eliminar este backup?');">Eliminar</a>

                                    </td>
                                </tr>
                            {% else %}
                                <tr><td colspan="4" class="text-center text-muted">Nenhum backup.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        {# ---------------- TAB DASHBOARD ---------------- #}
        <div class="tab-pane fade" id="dashboard">
            <div class="card">
                <div class="card-body">
                    {% include "admin/backups/dashboard.twig" %}
                </div>
            </div>
        </div>

        {# ---------------- TAB LOGS ---------------- #}
        <div class="tab-pane fade" id="logs">
            <div class="card">
                <div class="card-body">
                    {% include "admin/backups/logs.twig" %}
                </div>
            </div>
        </div>

    </div>

{% endblock %}
