{% extends "@admin/layout.twig" %}

{% block page_title %}
    <i class="fa fa-bell"></i> Notificações
{% endblock %}

{% block content %}

<div class="card">
    <div class="card-body">

        <h4 class="mb-4">Todas as Notificações</h4>

        <ul class="list-group">

            {% for n in notificacoes %}
                <li class="list-group-item d-flex justify-content-between align-items-start
                           {{ n.lida ? '' : 'fw-bold' }}">

                    <div>
                        {{ n.mensagem }}
                        <div class="text-muted small">{{ n.criado_em|date("d/m/Y H:i") }}</div>
                    </div>

                    {% if n.documento_id %}
                        <a href="/admin/tramitacao/{{ n.documento_id }}" class="btn btn-sm btn-primary">
                            Abrir
                        </a>
                    {% endif %}
                </li>
            {% endfor %}

        </ul>

    </div>
</div>

{% endblock %}

