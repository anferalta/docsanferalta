{# ============================================================
   MODAL: ENCAMINHAR DOCUMENTO
============================================================ #}
<div class="modal fade" id="modalTramitar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <form method="POST"
              action="/admin/tramitacao/encaminhar"
              enctype="multipart/form-data"
              class="modal-content"
              id="formEncaminhar">

            {{ csrf_field() }}

            <input type="hidden" name="documento_id" value="{{ documento.id }}">

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-random me-2"></i> Encaminhar Documento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- ÁREA DESTINO -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Área de destino</label>
                    <select name="area_id" class="form-select" required>
                        <option value="">Selecione...</option>
                        {% for a in areas %}
                            <option value="{{ a.id }}">{{ a.nome }}</option>
                        {% endfor %}
                    </select>
                </div>

                <!-- COMENTÁRIO -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Comentário (opcional)</label>
                    <textarea name="comentario"
                              class="form-control"
                              rows="3"
                              placeholder="Descreva o motivo do encaminhamento..."></textarea>
                </div>

                <!-- ANEXOS -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Anexos (opcional)</label>
                    <input type="file"
                           name="anexos[]"
                           class="form-control"
                           multiple>

                    <small class="text-muted">
                        Pode anexar vários ficheiros. Tamanho máximo por ficheiro: 20MB.
                    </small>
                </div>

            </div>

            <div class="modal-footer">
                <button type="submit" class="btn btn-primary" id="btnTramitar">
                    <i class="fa fa-paper-plane me-1"></i> Encaminhar
                </button>
            </div>

        </form>
    </div>
</div>


{# ============================================================
   MODAL: COMENTAR DOCUMENTO
============================================================ #}
<div class="modal fade" id="modalComentar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="POST"
              action="/admin/tramitacao/comentar"
              enctype="multipart/form-data"
              class="modal-content"
              id="formComentar">

            {{ csrf_field() }}

            <input type="hidden" name="documento_id" value="{{ documento.id }}">

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-comment me-1"></i> Adicionar Comentário
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- COMENTÁRIO -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Comentário</label>
                    <textarea name="comentario"
                              class="form-control"
                              rows="4"
                              required
                              placeholder="Escreva o seu comentário..."></textarea>
                </div>

                <!-- ANEXOS -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Anexos (opcional)</label>
                    <input type="file" name="anexos[]" class="form-control" multiple>
                </div>

            </div>

            <div class="modal-footer">
                <button type="submit" class="btn btn-secondary" id="btnComentar">
                    <i class="fa fa-save me-1"></i> Guardar Comentário
                </button>
            </div>

        </form>
    </div>
</div>


{# ============================================================
   MODAL: ALTERAR ESTADO DO DOCUMENTO
============================================================ #}
<div class="modal fade" id="modalEstado" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form method="POST"
              action="/admin/tramitacao/estado"
              enctype="multipart/form-data"
              class="modal-content"
              id="formEstado">

            {{ csrf_field() }}

            <input type="hidden" name="documento_id" value="{{ documento.id }}">

            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fa fa-flag me-1"></i> Alterar Estado do Documento
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <!-- ESTADO -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Novo estado</label>
                    <select name="estado" class="form-select" required>
                        <option value="">Selecione...</option>
                        {% for e in estados %}
                            {% if e.codigo != 'arquivado' %}
                                <option value="{{ e.codigo }}">{{ e.nome }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>

                <!-- COMENTÁRIO -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Comentário (opcional)</label>
                    <textarea name="comentario" class="form-control" rows="3"></textarea>
                </div>

                <!-- ANEXOS -->
                <div class="mb-3">
                    <label class="form-label fw-semibold">Anexos (opcional)</label>
                    <input type="file" name="anexos[]" class="form-control" multiple>
                </div>

            </div>

            <div class="modal-footer">
                <button type="submit" class="btn btn-warning" id="btnEstado">
                    <i class="fa fa-check me-1"></i> Alterar Estado
                </button>
            </div>

        </form>
    </div>
</div>
