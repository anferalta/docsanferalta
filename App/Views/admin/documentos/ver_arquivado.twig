{% extends "admin/layout.twig" %}

{% block content %}

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Documento Arquivado</h4>

        <form action="/admin/documentos/arquivado/{{ documento.id }}/recuperar" method="post">
            <button class="btn btn-warning"
                    onclick="return confirm('Tem a certeza que deseja recuperar este documento?')">
                Recuperar para Produção
            </button>
        </form>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <strong>Detalhes do Documento</strong>
        </div>
        <div class="card-body">
            <p><strong>Título:</strong> {{ documento.titulo }}</p>
            <p><strong>Tipo:</strong> {{ documento.tipo_nome ?? '—' }}</p>
            <p><strong>Arquivado em:</strong> {{ documento.arquivado_em|date("d/m/Y H:i") }}</p>
            <p><strong>Criado por:</strong> {{ documento.criador_nome ?? '—' }}</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <strong>Ficheiro</strong>
        </div>
        <div class="card-body">
            <a href="/admin/documentos/abrir/{{ documento.id }}"
               target="_blank"
               class="btn btn-primary">
                Abrir Ficheiro
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <strong>Histórico de Tramitação</strong>
        </div>

        <div class="card-body">

            {% if historico is empty %}
                <p class="text-muted text-center py-4">
                    Sem histórico de tramitação.
                </p>
            {% else %}

                <div class="timeline">

                    {% for h in historico %}

                        <div class="timeline-item">

                            {# ÍCONE + COR PADRONIZADOS #}
                            <div class="timeline-icon 
                                 {% if h.acao == 'ENCAMINHADO' %} bg-primary
                                 {% elseif h.acao == 'COMENTARIO' %} bg-info
                                 {% elseif h.acao == 'ESTADO' %} bg-success
                                 {% elseif h.acao == 'RECUPERAR' %} bg-warning
                                 {% else %} bg-secondary
                                 {% endif %}
                                 ">
                                <i class="
                                   {% if h.acao == 'ENCAMINHADO' %} fa fa-random
                                   {% elseif h.acao == 'COMENTARIO' %} fa fa-comment
                                   {% elseif h.acao == 'ESTADO' %} fa fa-flag
                                   {% elseif h.acao == 'RECUPERAR' %} fa fa-undo
                                   {% else %} fa fa-info-circle
                                   {% endif %}
                                   "></i>
                            </div>

                            <div class="timeline-content">

                                {# TEXTO PADRONIZADO #}
                                {% if h.acao == 'ENCAMINHADO' %}
                                    <p>
                                        <strong>{{ h.utilizador_nome }}</strong>
                                        encaminhou o documento para a área
                                        <strong>{{ h.area_nome ?: '—' }}</strong>.
                                    </p>

                                {% elseif h.acao == 'COMENTARIO' %}
                                    <p>
                                        <strong>{{ h.utilizador_nome }}</strong> adicionou um comentário:</p>
                                    <div class="bg-light border rounded p-2">
                                        {{ h.comentario|nl2br }}
                                    </div>

                                {% elseif h.acao == 'ESTADO' %}
                                    <p>
                                        <strong>{{ h.utilizador_nome }}</strong>
                                        alterou o estado para
                                        <strong>{{ h.estado|upper }}</strong>.
                                    </p>

                                {% elseif h.acao == 'RECUPERAR' %}
                                    <p>
                                        <strong>{{ h.utilizador_nome }}</strong>
                                        recuperou o documento do arquivo.
                                    </p>

                                {% else %}
                                    <p>
                                        <strong>{{ h.utilizador_nome }}</strong>
                                        realizou uma ação: <strong>{{ h.acao }}</strong>.
                                    </p>
                                {% endif %}

                                <small class="text-muted">
                                    {{ h.criado_em|date("d/m/Y H:i") }}
                                </small>

                            </div>
                        </div>

                    {% endfor %}

                </div>

            {% endif %}

        </div>
    </div>

{% endblock %}

