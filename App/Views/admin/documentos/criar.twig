{% extends "@admin/layout.twig" %}

{% block page_title %}Novo Documento{% endblock page_title %}

{% block content %}

<form id="upload-form"
      method="post"
      action="/admin/documentos/criar"
      enctype="multipart/form-data"
      class="card p-4 shadow-sm"
      novalidate>

    <input type="hidden" name="_csrf" value="{{ csrf_token() }}">

    <div class="alert alert-info">
        <strong>Informações importantes:</strong>
        <ul class="mb-0">
            <li>Pode enviar vários ficheiros ao mesmo tempo.</li>
            <li>Tamanho máximo por ficheiro: <strong>10 MB</strong>.</li>
            <li>Máximo de <strong>10 ficheiros</strong>.</li>
            <li>Tipos permitidos: <strong>PDF, DOCX, XLSX, JPG, PNG, TXT</strong>.</li>
        </ul>
    </div>

    <div class="mb-3">
        <label class="form-label"><strong>Título:</strong></label>
        <input type="text" name="titulo" id="titulo" class="form-control" required>
        <div id="tituloErro" class="text-danger mt-1 d-none">O título é obrigatório.</div>
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo de Documento</label>
        <div class="input-group">
            <select name="tipo_id" id="tipo_id" class="form-select" required>
                <option value="">-- Selecione --</option>
                {% for tipo in tipos %}
                    <option value="{{ tipo.id }}">{{ tipo.nome }}</option>
                {% endfor %}
            </select>
        </div>
    </div>

    <div id="dropZone" class="drop-zone mb-3">
        <div class="dz-content">
            <i class="fa fa-cloud-upload-alt dz-icon"></i>
            <p class="dz-title">Arraste ficheiros aqui</p>
            <p class="dz-subtitle">ou clique para selecionar</p>
        </div>
    </div>

    <div id="fileCounter" class="text-muted small mb-2 d-none"></div>

    <ul id="fileList" class="file-list list-group mb-3"></ul>

    <div id="fileLimitWarning" class="alert alert-warning d-none">
        Máximo de 10 ficheiros. Remova alguns para continuar.
    </div>

    <input type="file"
           name="ficheiros[]"
           id="ficheiros"
           multiple
           class="d-none">

    {# --- ÁREA DE PRÉ‑VISUALIZAÇÃO --- #}
    <div id="previewContainer" class="mb-3 d-none">
        <label class="form-label"><strong>Pré‑visualização:</strong></label>
        <div id="previewArea" class="border rounded p-3 text-center"></div>
    </div>

    <button type="submit" id="btnGuardar" class="btn btn-primary mt-3">
        <i class="fa fa-check"></i> Guardar
    </button>

</form>

{% endblock content %}

{% block scripts %}
    <script src="/assets/js/documentos/upload.js?v=316113716"></script>
    <script src="/assets/js/documentos/tipos.js?v=258413354"></script>

    <script>
        function atualizarPreview() {
            const input = document.getElementById('ficheiros');
            const previewContainer = document.getElementById('previewContainer');
            const previewArea = document.getElementById('previewArea');

            previewArea.innerHTML = '';

            if (input.files.length === 0) {
                previewContainer.classList.add('d-none');
                return;
            }

            previewContainer.classList.remove('d-none');

            [...input.files].forEach(file => {
                const ext = file.name.split('.').pop().toLowerCase();

                // IMAGENS
                if (['jpg', 'jpeg', 'png', 'gif', 'webp'].includes(ext)) {
                    const reader = new FileReader();
                    reader.onload = e => {
                        const img = document.createElement('img');
                        img.src = e.target.result;
                        img.className = "img-fluid mb-2";
                        img.style.maxHeight = "250px";
                        previewArea.appendChild(img);
                    };
                    reader.readAsDataURL(file);
                }

                // PDF
                else if (ext === 'pdf') {
                    const reader = new FileReader();
                    reader.onload = e => {
                        previewArea.innerHTML += `
                            <div class="mb-3">
                                <embed src="${e.target.result}" type="application/pdf" width="100%" height="400px" />
                                <div class="small text-muted mt-1">${file.name}</div>
                            </div>`;
                    };
                    reader.readAsDataURL(file);
                }

                // DOCX / XLSX / TXT → ícone
                else {
                    previewArea.innerHTML += `
                        <div class="mb-2">
                            <i class="fa fa-file-alt fa-3x text-secondary"></i><br>
                            ${file.name}
                        </div>`;
                }
            });
        }

        // Quando o input muda
        document.getElementById('ficheiros').addEventListener('change', atualizarPreview);

        // Quando o dropZone atualiza a lista (evento disparado pelo upload.js)
        document.addEventListener('ficheirosAtualizados', atualizarPreview);
    </script>
{% endblock scripts %}
