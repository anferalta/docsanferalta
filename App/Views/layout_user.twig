<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Dashboard{% endblock %}</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <link rel="stylesheet" href="/assets/css/badges.css">

    <style>
        body {
            background: #f5f6fa;
            margin: 0;
            padding: 0;
        }

        /* SIDEBAR FIXO */
        .sidebar-user {
            width: 240px;
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            background: #ffffff;
            border-right: 1px solid #ddd;
            padding: 20px;
            overflow-y: auto;
        }

        /* CONTEÚDO */
        .content-area {
            margin-left: 240px;
            padding: 30px;
            min-height: 100vh;
        }

        /* LINKS DO SIDEBAR */
        .nav-link {
            color: #333;
            font-weight: 500;
            border-radius: 6px;
            padding: 10px 12px;
        }

        .nav-link:hover {
            background: #f0f0f0;
        }

        .nav-link.active {
            background: #0d6efd;
            color: white !important;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar-user">
        {% include "partials/sidebar_user.twig" %}
    </div>

    <!-- CONTEÚDO -->
    <div class="content-area">
        {% block content %}{% endblock %}
    </div>

    <!-- SCRIPTS DEVEM FICAR AQUI (IMPORTANTE PARA O UPLOAD.JS FUNCIONAR) -->
    {% block scripts %}{% endblock %}

</body>
</html>
