{% extends "@site/layout.twig" %}

{% block title %}Recuperar Password{% endblock %}

{% block content %}
<div class="card mx-auto" style="max-width:480px;">
    <div class="card-header bg-warning text-dark text-center fw-bold">
        Recuperar Password
    </div>

    <div class="card-body">

        {% if flash %}
            {% for tipo, mensagem in flash %}
                <div class="alert alert-{{ tipo }}">
                    {{ mensagem }}
                </div>
            {% endfor %}
        {% endif %}

        <form method="post" class="row g-3">
            {{ csrf_field() }}

            <div class="col-12">
                <label class="form-label" for="email">Email associado à conta</label>
                <input class="form-control" type="email" id="email" name="email" required autocomplete="off">
            </div>

            <div class="col-12 mt-3 d-flex justify-content-between">
                <button class="btn btn-warning" type="submit">Enviar link de recuperação</button>
                <a href="/login" class="btn btn-outline-secondary">Voltar ao login</a>
            </div>
        </form>

    </div>
</div>
{% endblock %}
